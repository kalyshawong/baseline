# Database (SQLite — stored locally)
DATABASE_URL="file:./dev.db"

# Oura OAuth2 — Register at https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID="your_oura_client_id"
OURA_CLIENT_SECRET="your_oura_client_secret"
OURA_REDIRECT_URI="http://localhost:3000/api/auth/oura/callback"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sync API key — protect the sync endpoint (generate any random string)
SYNC_API_KEY="generate-a-random-secret-here"

# Anthropic API key — used for nutrition macro estimation
ANTHROPIC_API_KEY="your_anthropic_api_key"

# Environment sensor API key (for ESP32 → Baseline data push)
# SENSOR_API_KEY="generate-another-random-secret"
