// ---------------------------------------------------------------------------
// Mind Mode
// ---------------------------------------------------------------------------

model Experiment {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title               String
  hypothesis          String
  independentVariable String
  dependentVariable   String
  dependentMetric     String
  metricSource        String
