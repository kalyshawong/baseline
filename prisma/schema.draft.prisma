// ============================================================================
// MULTI-TENANT DRAFT SCHEMA — review before adopting. Drafted June 16, 2026.
//
// Changes vs current schema.prisma:
//   1. Provider sqlite -> postgresql
//   2. New `User` model (the tenant) + `UserBaseline` (per-signal maturity/stats)
//   3. `userId` + relation on every user-owned table, incl. denormalized onto
//      child tables (for simple Supabase RLS) — see MULTITENANCY_AUDIT.md Tier 2
//   4. Every `day @unique` -> `@@unique([userId, day])`; natural-key uniques
//      get userId folded in (Tier 1)
//   5. UserProfile + OuraToken go from singletons to one-per-user
//   6. Exercise gets nullable userId: null = shared seed catalog, set = custom
//
// NOT done here (deliberately): RLS policies (live in Supabase, not Prisma),
// the 305-callsite query sweep, and data backfill. This is the shape only.
// ============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider  = "postgresql"
  // Supabase: pooled connection (PgBouncer, port 6543, ?pgbouncer=true) for the
  // app/serverless. Migrations need a direct connection (port 5432) — directUrl.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Tenant
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Onboarding anchor — when this user first synced data. Baseline maturity
  // (see UserBaseline) is measured against per-signal data sufficiency, but
  // this gives a single "day 0" for the top-level "still learning" banner.
  baselineStartedAt DateTime?

  // back-relations
  ouraToken                OuraToken?
  profile                  UserProfile?
  baselines                UserBaseline[]
  dailyReadiness           DailyReadiness[]
  dailySleep               DailySleep[]
  dailyActivity            DailyActivity[]
  dailyStress              DailyStress[]
  heartRateSamples         HeartRateSample[]
  cyclePhaseLogs           CyclePhaseLog[]
  syncLogs                 SyncLog[]
  experiments              Experiment[]
  experimentLogs           ExperimentLog[]
  activityTags             ActivityTag[]
  nutritionLogs            NutritionLog[]
  nutritionEntries         NutritionEntry[]
  exercises                Exercise[]
  workoutSessions          WorkoutSession[]
  workoutSets              WorkoutSet[]
  workoutTemplates         WorkoutTemplate[]
  goals                    Goal[]
  hyroxPlans               HyroxPlan[]
  hyroxSessions            HyroxSession[]
  hyroxStationBenchmarks   HyroxStationBenchmark[]
  goalWorkoutTags          GoalWorkoutTag[]
  chatSessions             ChatSession[]
  chatMessages             ChatMessage[]
  weightLogs               WeightLog[]
  healthKitSyncs           HealthKitSync[]
  healthKitWorkouts        HealthKitWorkout[]
  heartRateZoneSummaries   HeartRateZoneSummary[]
  dailySpO2                DailySpO2[]
  ouraWorkouts             OuraWorkout[]
  ouraSessions             OuraSession[]
  sleepTimeRecommendations SleepTimeRecommendation[]
  dailyResilience          DailyResilience[]
  dailyRunningMetrics      DailyRunningMetrics[]
  dailyVO2Max              DailyVO2Max[]
  envReadings              EnvReading[]
  lifeContextDefs          LifeContextDef[]
  lifeContextLogs          LifeContextLog[]
  workoutNotes             WorkoutNote[]
}

// Per-user, per-signal baseline state. This is the gate between "priors mode"
// (coach leans on shared research) and "personalized mode" (coach uses the
// user's own baseline). Recomputed on each sync from the daily/sample tables;
// cached here so the dashboard/coach don't recompute rolling stats per request.
//
// THIS is where per-user calibration lives — e.g. the HRV-CV overreaching
// cutoff is derived from THIS row's cv, never a hardcoded 10% constant. The
// maturity *rules* (minDays per signal) stay in code as shared engine config.
model UserBaseline {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Which signal: "hrv" | "rhr" | "sleepScore" | "sleepDuration" |
  // "readiness" | "stress" | "cyclePhase" | "runningSpeed" | ...
  signal String

  // Data sufficiency
  n              Int       @default(0) // days/points observed
  firstDay       DateTime?
  lastDay        DateTime?
  spanDays       Int       @default(0)
  cyclesObserved Int? // for cycle-modulated signals; null if N/A

  // Computed baseline — null until mature
  mean Float?
  sd   Float?
  cv   Float? // per-user coefficient of variation (the HRV-CV fix lives here)
  p20  Float? // personal range bounds (percentiles), optional
  p80  Float?

  // Maturity gate
  isMature    Boolean  @default(false)
  maturityPct Float    @default(0) // 0..1 — drives the onboarding "learning" UI
  computedAt  DateTime @updatedAt

  @@unique([userId, signal])
  @@index([userId])
}

