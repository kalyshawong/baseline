  startDate           DateTime
  endDate             DateTime?
  minDays             Int       @default(14)
  status              String    @default("draft")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  logs ExperimentLog[]
  tags ActivityTag[]

  @@index([userId])
}

model ExperimentLog {
  id               String     @id @default(cuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  experimentId     String
  experiment       Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  day              DateTime
  independentValue Boolean
  intensity        Float?
  notes            String?
  createdAt        DateTime   @default(now())

  @@unique([experimentId, day])
  @@index([userId])
}

model ActivityTag {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag          String
  category     String
  timestamp    DateTime    @default(now())
  metadata     String?
  experimentId String?
  experiment   Experiment? @relation(fields: [experimentId], references: [id])
  ouraTagId    String?
  source       String      @default("manual")
  createdAt    DateTime    @default(now())

  @@unique([userId, ouraTagId])
  @@index([userId])
}

model NutritionLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       DateTime
  calories  Float    @default(0)
  protein   Float    @default(0)
  carbs     Float    @default(0)
  fat       Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries NutritionEntry[]

  @@unique([userId, day])
  @@index([userId])
}

enum MealSource {
  home_cooked
  takeout
  restaurant
  pre_packaged
}

model NutritionEntry {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  nutritionLogId String
  nutritionLog   NutritionLog @relation(fields: [nutritionLogId], references: [id], onDelete: Cascade)
  description    String
  calories       Float
  protein        Float
  carbs          Float
  fat            Float
  quantity       Float        @default(1)
  unit           String       @default("serving")
  foodName       String
  mealType       String       @default("snack")
  source         MealSource?
  eatenAt        DateTime     @default(now())
  timeUnknown    Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Body Mode
// ---------------------------------------------------------------------------

// Exercise: null userId = shared seed catalog; set userId = user's custom.
// NOTE: Postgres treats NULLs as distinct in unique constraints, so the
// @@unique([userId, name]) does NOT prevent duplicate *global* names — keep
// the seed catalog controlled (seeded once), it only enforces per-user custom
// uniqueness. If you want strict global uniqueness too, enforce it in app code
// or with a partial index added in a raw migration.
model Exercise {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  muscleGroup     String
  secondaryMuscle String?
  movementPattern String
  equipment       String
  isCompound      Boolean  @default(false)
  defaultSets     Int      @default(3)
  defaultReps     Int      @default(10)
  notes           String?
  createdAt       DateTime @default(now())

  sets WorkoutSet[]

  @@unique([userId, name])
  @@index([userId])
}

model WorkoutSession {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  durationMin    Int?
  readinessScore Int?
  cyclePhase     String?
  sessionRPE     Int?
  sessionVolume  Float?
  notes          String?
  templateName   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sets         WorkoutSet[]
  goalTags     GoalWorkoutTag[]
  hyroxSession HyroxSession?

  @@index([userId])
}

model WorkoutSet {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String
  session     WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise       @relation(fields: [exerciseId], references: [id])
  setNumber   Int
  reps        Int
  weight      Float
  rpe         Int?
  restSeconds Int?
  isWarmup    Boolean        @default(false)
  isPR        Boolean        @default(false)
  notes       String?
  createdAt   DateTime       @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([exerciseId])
}

model WorkoutTemplate {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  split     String   @default("custom")
  exercises String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

// One profile per user (was a hardcoded id=1 singleton).
model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bodyWeightKg       Float?
  bodyFatPct         Float?
  heightCm           Float?
  age                Int?
  sex                String?
  experienceLevel    String   @default("intermediate")
  activityLevel      String   @default("moderate")
  goal               String   @default("maintain")
  targetWeightKg     Float?
  dailyCalorieTarget Int?
  unit               String   @default("lb")
  hrvBaselineChoice  String   @default("pending") // pending | personalized | standard
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Goal {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  type      String
  subtype   String?
  target    String?
  deadline  DateTime?
  status    String    @default("active")
  isPrimary Boolean   @default(false)
  priority  Int       @default(0)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  workoutTags GoalWorkoutTag[]
  hyroxPlan   HyroxPlan?

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Hyrox Race-Prep Module
// ---------------------------------------------------------------------------

model HyroxPlan {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId     String   @unique
  goal       Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  raceDate   DateTime
  targetTime Int
  startDate  DateTime @default(now())

  weeklyRunHours         Float @default(3.0)
  weeklyStrengthHours    Float @default(2.0)
  weeklyCompromisedHours Float @default(1.0)

  accumulationDays  Int @default(14)
  transmutationDays Int @default(14)
  realizationDays   Int @default(11)
  taperDays         Int @default(14)

  currentBlock   String   @default("accumulation")
  blockStartDate DateTime @default(now())
  status         String   @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions          HyroxSession[]
  stationBenchmarks HyroxStationBenchmark[]

  @@index([userId])
}

model HyroxSession {
  id     String    @id @default(cuid())
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId String
  plan   HyroxPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  workoutSessionId String?         @unique
  workoutSession   WorkoutSession? @relation(fields: [workoutSessionId], references: [id], onDelete: SetNull)

  day         DateTime
  sessionType String

  stationOrderJson    String?
  transitionTimesJson String?
  racePaceTargetJson  String?
  intervalsJson       String?

  prescriptionNotes String?
  rationale         String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([planId])
  @@index([day])
}

model HyroxStationBenchmark {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId      String
  plan        HyroxPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  station     String
  timeSeconds Int
  weightKg    Float?
  notes       String?
  recordedAt  DateTime  @default(now())

  @@index([userId])
  @@index([planId, station])
}

model GoalWorkoutTag {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId    String
  goal      Goal           @relation(fields: [goalId], references: [id], onDelete: Cascade)
  sessionId String
  session   WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([goalId, sessionId])
  @@index([userId])
}

