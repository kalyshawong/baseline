generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model OuraToken {
  id           Int      @id @default(autoincrement())
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DailyReadiness {
  id                        String   @id
  day                       DateTime @unique
  score                     Int?
  temperatureDeviation      Float?
  temperatureTrendDeviation Float?
  hrvBalance                Int?
  bodyTemperature           Int?
  recoveryIndex             Int?
  restingHeartRate          Int?
  sleepBalance              Int?
  activityBalance           Int?
  createdAt                 DateTime @default(now())
}

model DailySleep {
  id                 String   @id
  day                DateTime @unique
  score              Int?
  totalSleepDuration Int?
  remSleepDuration   Int?
  deepSleepDuration  Int?
  lightSleepDuration Int?
  sleepEfficiency    Int?
  latency            Int?
  averageHeartRate   Float?
  lowestHeartRate    Int?
  averageHrv         Int?
  createdAt          DateTime @default(now())
}

model DailyActivity {
  id                        String   @id
  day                       DateTime @unique
  score                     Int?
  activeCalories            Int?
  totalCalories             Int?
  steps                     Int?
  equivalentWalkingDistance Int?
  highActivityTime          Int? // seconds
  mediumActivityTime        Int?
  lowActivityTime           Int?
  sedentaryTime             Int?
  restingTime               Int?
  metMinutes                Int?
  createdAt                 DateTime @default(now())
}

model DailyStress {
  id           String   @id
  day          DateTime @unique
  stressHigh   Int?
  recoveryHigh Int?
  daySummary   String?
  createdAt    DateTime @default(now())
}

model HeartRateSample {
  id        Int      @id @default(autoincrement())
  bpm       Int
  source    String
  timestamp DateTime

  @@unique([timestamp, source])
}

model CyclePhaseLog {
  id        Int      @id @default(autoincrement())
  day       DateTime @unique
  phase     String // menstrual | follicular | ovulation | luteal
  source    String   @default("manual")
  createdAt DateTime @default(now())
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  syncDate  DateTime @default(now())
  status    String // success | partial | failed
  details   String?
  createdAt DateTime @default(now())
}

// --- Mind Mode ---

model Experiment {
  id                  String    @id @default(cuid())
  title               String
  hypothesis          String
  independentVariable String
  dependentVariable   String
  dependentMetric     String // field name: deepSleepDuration, averageHrv, score, etc.
  metricSource        String // DailySleep | DailyReadiness | DailyStress | HeartRateSample
  lagDays             Int       @default(0) // 0 = same day, 1 = next day, etc.
  startDate           DateTime
  endDate             DateTime?
  minDays             Int       @default(14)
  status              String    @default("draft") // draft | active | completed | analyzed
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  logs ExperimentLog[]
  tags ActivityTag[]
}

model ExperimentLog {
  id               String     @id @default(cuid())
  experimentId     String
  experiment       Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  day              DateTime
  independentValue Boolean // true = condition applied, false = control
  intensity        Float? // optional 0.0-1.0 for variable-dose experiments
  notes            String?
  createdAt        DateTime   @default(now())

  @@unique([experimentId, day])
}

model ActivityTag {
  id           String      @id @default(cuid())
  tag          String
  category     String // music | breathing | caffeine | alcohol | meditation | exercise | social | study | custom
  timestamp    DateTime    @default(now())
  metadata     String? // JSON string for flexible extra data
  experimentId String?
  experiment   Experiment? @relation(fields: [experimentId], references: [id])
  ouraTagId    String?     @unique // Oura enhanced_tag ID for dedup
  source       String      @default("manual") // manual | oura | healthkit
  createdAt    DateTime    @default(now())
}

model NutritionLog {
  id        String   @id @default(cuid())
  day       DateTime @unique
  calories  Float    @default(0)
  protein   Float    @default(0)
  carbs     Float    @default(0)
  fat       Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries NutritionEntry[]
}

model NutritionEntry {
  id             String       @id @default(cuid())
  nutritionLogId String
  nutritionLog   NutritionLog @relation(fields: [nutritionLogId], references: [id], onDelete: Cascade)
  description    String // "3 eggs", "200g ground beef"
  calories       Float
  protein        Float
  carbs          Float
  fat            Float
  quantity       Float        @default(1) // parsed quantity
  unit           String       @default("serving") // g, oz, cup, serving
  foodName       String // normalized name from USDA match
  mealType       String       @default("snack") // breakfast | lunch | dinner | snack
  eatenAt        DateTime     @default(now()) // actual time the food was eaten
  timeUnknown    Boolean      @default(false) // true = user didn't remember exact time; eatenAt anchored at day start
  createdAt      DateTime     @default(now())
}

// --- Body Mode ---

model Exercise {
  id              String   @id @default(cuid())
  name            String   @unique
  muscleGroup     String // chest | back | shoulders | biceps | triceps | quads | hamstrings | glutes | calves | core
  secondaryMuscle String?
  movementPattern String // push | pull | hinge | squat | carry | isolation | olympic
  equipment       String // barbell | dumbbell | cable | machine | bodyweight | kettlebell | band
  isCompound      Boolean  @default(false)
  defaultSets     Int      @default(3)
  defaultReps     Int      @default(10)
  notes           String?
  createdAt       DateTime @default(now())

  sets WorkoutSet[]
}

model WorkoutSession {
  id             String    @id @default(cuid())
  date           DateTime
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  durationMin    Int?
  readinessScore Int?
  cyclePhase     String?
  sessionRPE     Int?
  sessionVolume  Float?
  notes          String?
  templateName   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sets         WorkoutSet[]
  goalTags     GoalWorkoutTag[]
  hyroxSession HyroxSession?
}

model WorkoutSet {
  id          String         @id @default(cuid())
  sessionId   String
  session     WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise       @relation(fields: [exerciseId], references: [id])
  setNumber   Int
  reps        Int
  weight      Float
  rpe         Int?
  restSeconds Int?
  isWarmup    Boolean        @default(false)
  isPR        Boolean        @default(false)
  notes       String?
  createdAt   DateTime       @default(now())

  @@index([sessionId])
  @@index([exerciseId])
}

model WorkoutTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  split     String   @default("custom") // PPL | Upper/Lower | custom
  exercises String // JSON array of { exerciseName, targetSets, targetReps }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id                 Int      @id @default(1)
  bodyWeightKg       Float?
  bodyFatPct         Float?
  heightCm           Float?
  age                Int?
  sex                String? // female | male
  experienceLevel    String   @default("intermediate") // beginner | intermediate | advanced
  activityLevel      String   @default("moderate") // sedentary | light | moderate | active | very_active
  goal               String   @default("maintain") // lose | maintain | gain
  targetWeightKg     Float?
  dailyCalorieTarget Int?
  unit               String   @default("lb") // lb | kg
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Goal {
  id        String    @id @default(cuid())
  title     String
  type      String // race | strength | physique | cognitive | weight | health | custom
  subtype   String? // hyrox | marathon | half_marathon | 5k | 10k | triathlon | powerlifting_meet | bodybuilding | cfa | finals | certification | cut | bulk | recomp | maintain | sleep_optimization | hrv_baseline | stress_management | custom
  target    String?
  deadline  DateTime?
  status    String    @default("active") // active | completed | abandoned | archived
  isPrimary Boolean   @default(false)
  priority  Int       @default(0)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  workoutTags GoalWorkoutTag[]
  hyroxPlan   HyroxPlan?
}

// --- Hyrox Race-Prep Module ---

model HyroxPlan {
  id         String   @id @default(cuid())
  goalId     String   @unique
  goal       Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  raceDate   DateTime
  targetTime Int // total seconds (e.g., 85min = 5100)
  startDate  DateTime @default(now())

  // Weekly targets (hours) — auto-derived from block at creation, user-editable
  weeklyRunHours         Float @default(3.0)
  weeklyStrengthHours    Float @default(2.0)
  weeklyCompromisedHours Float @default(1.0)

  // Block schedule (in days) — auto-scaled at creation based on weeksToRace,
  // user-editable thereafter. 0 allowed for accumulation on very short runways.
  accumulationDays  Int @default(14)
  transmutationDays Int @default(14)
  realizationDays   Int @default(11) // ~1.5 weeks
  taperDays         Int @default(14)

  // Current block state (computed from startDate + above, cached for display)
  currentBlock   String   @default("accumulation") // accumulation | transmutation | realization | taper | complete
  blockStartDate DateTime @default(now())

  // Lifecycle: active while race is upcoming; auto-archived after raceDate
  status String @default("active") // active | archived

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions          HyroxSession[]
  stationBenchmarks HyroxStationBenchmark[]
}

model HyroxSession {
  id     String    @id @default(cuid())
  planId String
  plan   HyroxPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  // FK to WorkoutSession (the canonical training record). Never duplicate
  // sets, reps, weights, HR — all of that lives on WorkoutSession. HyroxSession
  // is a thin race-specific layer.
  workoutSessionId String?         @unique
  workoutSession   WorkoutSession? @relation(fields: [workoutSessionId], references: [id], onDelete: SetNull)

  day         DateTime
  sessionType String // easy_run | tempo | intervals | long_run | strength | compromised | station_work | recovery | race_simulation

  // Race-specific layer (fields that only make sense for Hyrox-flavored sessions)
  stationOrderJson    String? // JSON array of station keys in the order performed
  transitionTimesJson String? // JSON array of seconds per transition
  racePaceTargetJson  String? // JSON { kmPaceSeconds, perStationBudget: { [key]: seconds } }
  intervalsJson       String? // compromised: JSON of { runMeters, runSeconds, station, stationReps, stationSeconds }[]

  // Plan-level metadata — actual performance numbers live on WorkoutSession
  prescriptionNotes String?
  rationale         String?

  createdAt DateTime @default(now())

  @@index([planId])
  @@index([day])
}

model HyroxStationBenchmark {
  id          String    @id @default(cuid())
  planId      String
  plan        HyroxPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  station     String // ski_erg | sled_push | sled_pull | burpee_broad_jump | row | farmers_carry | sandbag_lunges | wall_balls
  timeSeconds Int
  weightKg    Float?
  notes       String?
  recordedAt  DateTime  @default(now())

  @@index([planId, station])
}

model GoalWorkoutTag {
  id        String         @id @default(cuid())
  goalId    String
  goal      Goal           @relation(fields: [goalId], references: [id], onDelete: Cascade)
  sessionId String
  session   WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([goalId, sessionId])
}

model ChatSession {
  id        String   @id @default(cuid())
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // user | assistant
  content   String
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

model WeightLog {
  id           String   @id @default(cuid())
  day          DateTime @unique
  weightKg     Float
  bodyFatPct   Float?
  muscleMassKg Float?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// --- HealthKit / Apple Watch ---

model HealthKitSync {
  id       String   @id @default(cuid())
  syncedAt DateTime @default(now())
  source   String   @default("health-auto-export")
  status   String // success | partial | failed
  details  String?
  metrics  Int      @default(0)
  workouts Int      @default(0)
}

model HealthKitWorkout {
  id              String   @id @default(cuid())
  externalId      String   @unique
  name            String
  startedAt       DateTime
  endedAt         DateTime
  durationSeconds Int
  activeCalories  Float?
  distance        Float?
  distanceUnit    String?
  avgHeartRate    Int?
  maxHeartRate    Int?
  minHeartRate    Int?
  source          String   @default("apple-watch")
  createdAt       DateTime @default(now())
}

model HeartRateZoneSummary {
  id           String   @id @default(cuid())
  workoutId    String?
  date         DateTime
  zone1Minutes Float    @default(0) // <60% max HR (recovery)
  zone2Minutes Float    @default(0) // 60-70% (fat burn)
  zone3Minutes Float    @default(0) // 70-80% (cardio)
  zone4Minutes Float    @default(0) // 80-90% (threshold)
  zone5Minutes Float    @default(0) // 90%+ (peak)
  createdAt    DateTime @default(now())
}

// --- Oura Expansion ---

model DailySpO2 {
  id        String   @id
  day       DateTime @unique
  avgSpO2   Float?
  createdAt DateTime @default(now())
}

model OuraWorkout {
  id              String   @id
  day             DateTime
  activity        String // cycling, running, strength_training, etc.
  calories        Float?
  distance        Float? // meters
  intensity       String? // easy | moderate | hard
  label           String?
  source          String? // manual | autodetected | apple_health
  startedAt       DateTime
  endedAt         DateTime
  durationSeconds Int
  createdAt       DateTime @default(now())

  @@index([day])
}

model OuraSession {
  id              String   @id
  day             DateTime
  type            String // breathing | meditation | nap | relaxation | rest | body_status
  startedAt       DateTime
  endedAt         DateTime
  durationSeconds Int
  avgHeartRate    Float?
  avgHrv          Float?
  mood            String?
  createdAt       DateTime @default(now())

  @@index([day])
}

model SleepTimeRecommendation {
  id                  String   @id
  day                 DateTime @unique
  optimalBedtimeStart Int? // seconds from midnight (negative = before midnight)
  optimalBedtimeEnd   Int?
  recommendation      String? // improve_efficiency | earlier_bedtime | later_bedtime | follow_optimal_bedtime
  status              String? // not_enough_nights | optimal_found | etc.
  createdAt           DateTime @default(now())
}

model DailyResilience {
  id              String   @id
  day             DateTime @unique
  level           String // limited | adequate | solid | strong | exceptional
  sleepRecovery   Int? // 0-100
  daytimeRecovery Int? // 0-100
  stress          Int? // 0-100
  createdAt       DateTime @default(now())
}

model DailyRunningMetrics {
  id                     String   @id @default(cuid())
  day                    DateTime @unique
  runningSpeed           Float? // avg km/h
  runningPower           Float? // avg watts
  groundContactTime      Float? // avg milliseconds
  verticalOscillation    Float? // avg cm
  strideLength           Float? // avg meters
  cardioRecovery         Float? // HR recovery metric (BPM drop post-workout)
  walkingRunningDistance Float? // total meters
  respiratoryRate        Float? // breaths per minute
  physicalEffort         Float? // Apple effort score
  createdAt              DateTime @default(now())

  @@index([day])
}

model DailyVO2Max {
  id        String   @id
  day       DateTime @unique
  vo2Max    Float? // mL/kg/min
  createdAt DateTime @default(now())
}

model EnvReading {
  id          String   @id @default(cuid())
  deviceId    String   @default("env-sensor-bedroom")
  timestamp   DateTime
  pm25        Float?
  temperature Float?
  humidity    Float?
  pressure    Float?
  noiseDb     Float?
  lux         Float?
  createdAt   DateTime @default(now())

  @@index([timestamp])
  @@index([deviceId, timestamp])
}

// --- Life Context ---
// Day-level state markers that don't fit ActivityTag's point-in-time model:
// "with partner", "alone in bed", "sick", "interview today", "studying for X".
// Designed to extend into spans (start/end) and events (with time) later;
// for now LifeContextLog is a day-flag only (one row per defId per day).

model LifeContextDef {
  id        String   @id @default(cuid())
  label     String   @unique // user-facing — "with partner", "alone", "sick", "exam day"
  category  String   @default("custom") // relationship | sleep | stressor | effort | milestone | illness | travel | cycle | custom
  emoji     String? // single character for fast recognition in the toggle row
  color     String? // tailwind palette key (e.g. "rose", "emerald") for UI consistency
  archived  Boolean  @default(false) // hide from quick-toggle without losing history
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs LifeContextLog[]
}

model LifeContextLog {
  id    String         @id @default(cuid())
  defId String
  def   LifeContextDef @relation(fields: [defId], references: [id], onDelete: Cascade)

  // Stored as UTC midnight of the local day, mirroring NutritionLog.day so it
  // composes with the rest of the day-keyed tables. The unique constraint
  // prevents accidental double-toggling of the same flag on the same day.
  day DateTime

  notes     String?
  createdAt DateTime @default(now())

  @@unique([defId, day])
  @@index([day])
}
